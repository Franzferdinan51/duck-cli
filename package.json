{
  "name": "@duckets/duck-cli-orchestrator",
  "version": "0.8.0",
  "description": "duck-cli v2 Orchestrator Core with Tool Registry and Fallback System",
  "main": "dist/orchestrator/index.js",
  "module": "dist/orchestrator/index.js",
  "types": "dist/orchestrator/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/orchestrator/index.js",
      "types": "./dist/orchestrator/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && cp -r src/vendor dist/vendor && cp src/vendor/*.js dist/vendor/ 2>/dev/null || true",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "demo": "node --loader ts-node/esm demo.ts"
  },
  "keywords": [
    "orchestrator",
    "tool-registry",
    "fallback-system",
    "duck-cli"
  ],
  "author": "Duckets",
  "license": "MIT",
  "devDependencies": {
    "@types/commander": "^2.12.0",
    "@types/cors": "^2.8.19",
    "@types/diff": "^7.0.2",
    "@types/express": "^5.0.6",
    "@types/glob": "^8.1.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "@types/yaml": "^1.9.6",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "diff": "^8.0.4",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.5.10",
    "glob": "^13.0.6",
    "typescript": "^5.3.0",
    "uuid": "^13.0.0",
    "yaml": "^2.8.3"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.1",
    "ws": "^8.20.0"
  }
}
