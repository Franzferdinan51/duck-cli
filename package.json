{
  "name": "duck-agent",
  "version": "0.1.0",
  "description": "🦆 Duck Agent - Super AI Agent with KAIROS Proactive AI, Voice/TTS, Web UI, Claude Code Tools",
  "main": "dist/agent/core.js",
  "bin": {
    "duck": "./dist/cli/main.js",
    "duck-agent": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx src/cli/main.ts",
    "dev:agent": "tsx src/agent/core.ts",
    "dev:web": "tsx src/web-server.ts",
    "test": "vitest",
    "lint": "eslint src/",
    "start": "node dist/cli/main.js gateway",
    "shell": "node dist/cli/main.js shell",
    "web": "node dist/cli/main.js web",
    "mcp": "node dist/cli/main.js mcp",
    "docker:build": "docker build -t duck-agent .",
    "docker:run": "docker-compose up -d",
    "docker:logs": "docker logs -f duck-agent"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^13.0.6",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/ws": "^8.18.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai-agent",
    "claude-code",
    "duck-agent",
    "kairos",
    "tts",
    "voice",
    "desktop-control",
    "mcp",
    "openclaw",
    "hermes",
    "browseros"
  ],
  "author": "Ryan (Duckets)",
  "license": "MIT",
  "homepage": "https://github.com/Franzferdinan51/duck-cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/Franzferdinan51/duck-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Franzferdinan51/duck-cli/issues"
  }
}
