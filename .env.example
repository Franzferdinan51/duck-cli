# Duck Agent Configuration
# Copy this file to .env and fill in your keys

# REQUIRED for AI features
# Get your key at: https://platform.minimax.io/
MINIMAX_API_KEY=your_minimax_api_key_here

# Optional: Override default provider (minimax, anthropic, openai, lmstudio)
# PROVIDER=minimax

# Optional: LM Studio (local models)
# LMSTUDIO_URL=http://localhost:1234
# LMSTUDIO_KEY=local

# Optional: OpenAI
# OPENAI_API_KEY=sk-...

# Optional: Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Web UI port (default: 3000)
# WEB_PORT=3000

# MCP server port (default: 3850)
# MCP_PORT=3850
