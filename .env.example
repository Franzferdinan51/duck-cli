# Duck Agent Configuration
# Copy this file to .env and fill in your keys

# REQUIRED for AI features
# Get your key at: https://platform.minimax.io/
MINIMAX_API_KEY=your_minimax_api_key_here

# Optional: Override default provider (minimax, anthropic, openai, lmstudio)
# PROVIDER=minimax

# Optional: LM Studio (OpenAI-compatible local/remote endpoint)
# LMSTUDIO_URL=http://localhost:1234
# LMSTUDIO_KEY=your_lmstudio_api_key_here
# LMSTUDIO_MODELS=gemma-4-e4b-it

# Optional: OpenClaw gateway / bridge
# OPENCLAW_GATEWAY=ws://localhost:18789
# OPENCLAW_GATEWAY_HTTP=http://localhost:18789

# Optional: Telegram bot / channel integrations
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# TELEGRAM_CHAT_ID=588090613

# Optional: MCP ports
# MCP_SERVER_PORT=3850
# MCP_BRIDGE_PORT=9090

# Optional: OpenAI
# OPENAI_API_KEY=sk-...

# Optional: Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: desktop / browser automation
# CLAWDCURSOR_URL=http://127.0.0.1:3847
# BROWSEROS_MCP_URL=http://127.0.0.1:9000/mcp

# Optional: trading / crypto / portfolio integrations
# UNUSUAL_WHALES_TOKEN=...
# PORTFOLIO_API_KEY=...

# Optional: grow / plant monitoring
# GROW_DEVICE_ID=...
# GROW_CAMERA_URL=...
# GROW_TENT_NAME=3x3 Tent

# Web UI port (default: 3000)
# WEB_PORT=3000
