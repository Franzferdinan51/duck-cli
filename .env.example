# Duck Agent Configuration
# Copy this file to .env and fill in your keys

# REQUIRED for AI features
# Get your key at: https://platform.minimax.io/
MINIMAX_API_KEY=your_minimax_api_key_here

# Optional: Override default provider (minimax, anthropic, openai, lmstudio)
# PROVIDER=minimax

# Optional: LM Studio (OpenAI-compatible local/remote endpoint)
# LMSTUDIO_URL=http://localhost:1234
# LMSTUDIO_KEY=your_lmstudio_api_key_here
# LMSTUDIO_MODELS=gemma-4-e4b-it

# Optional: OpenClaw gateway / bridge
# OPENCLAW_GATEWAY=ws://localhost:18789
# OPENCLAW_GATEWAY_HTTP=http://localhost:18789

# Optional: MCP ports
# MCP_SERVER_PORT=3850
# MCP_BRIDGE_PORT=9090

# Optional: OpenAI
# OPENAI_API_KEY=sk-...

# Optional: Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Web UI port (default: 3000)
# WEB_PORT=3000

# Web UI port (default: 3000)
# WEB_PORT=3000
