# 🦆 Duck Agent Environment Variables
# Copy this to .env and fill in your values

# ===========================================
# AI PROVIDERS (at least one required)
# ===========================================

# MiniMax API (Recommended - generous quota)
MINIMAX_API_KEY=sk-cp-your-key-here

# Alternative providers
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here

# LM Studio (local models - no API cost)
LMSTUDIO_URL=http://localhost:1234
LMSTUDIO_KEY=not-needed

# ===========================================
# BROWSER AUTOMATION
# ===========================================

# BrowserOS (browser automation - default port)
BROWSEROS_HOST=127.0.0.1
BROWSEROS_PORT=9100

# ===========================================
# GATEWAY & SECURITY
# ===========================================

# Gateway authentication token
GATEWAY_TOKEN=change-me-to-a-secret-token

# Web UI port
WEB_PORT=3000

# MCP Server port
MCP_PORT=3848

# Gateway port
GATEWAY_PORT=18789

# ===========================================
# CHANNELS (optional)
# ===========================================

# Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Discord
# DISCORD_BOT_TOKEN=your-bot-token
# DISCORD_APPLICATION_ID=123456789012345678

# ===========================================
# NOTIFICATIONS (optional)
# ===========================================

# Push notification service
# PUSHBULLET_TOKEN=your-token

# ===========================================
# COST TRACKING
# ===========================================

# Monthly budget limit (USD)
# COST_BUDGET=10.00
